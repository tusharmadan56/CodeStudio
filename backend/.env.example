NODE_ENV=development
PORT=3000
PROJECTS_DIR=./projects
SCAFFOLD_CMD=npm create vite@latest {{projectName}} -- --template react
DATABASE_URL=postgresql://codestudio:codestudio@localhost:5433/codestudio?schema=public

# node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_ACCESS_SECRET=replace-with-a-long-random-string
JWT_REFRESH_SECRET=replace-with-a-different-long-random-string
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# public site origin in production
CLIENT_ORIGIN=http://localhost:5173

# public host for sandbox preview URLs (VM ip / domain in production)
PREVIEW_HOST=localhost

# per-sandbox caps
SANDBOX_MEMORY_MB=512
SANDBOX_CPUS=1
SANDBOX_PIDS_LIMIT=256
